{
	"name": "rollbackit",
	"type": "module",
	"version": "1.0.1",
	"sideEffects": false,
	"description": "Automatic rollback for multi-step operations. Register an undo next to each step; if a later one throws, they unwind in reverse. Zero-dependency, type-safe.",
	"author": "Alexandre Marques",
	"license": "MIT",
	"homepage": "https://github.com/alexmarqs/rollbackit#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/alexmarqs/rollbackit.git"
	},
	"bugs": {
		"url": "https://github.com/alexmarqs/rollbackit/issues"
	},
	"publishConfig": {
		"access": "public"
	},
	"keywords": [
		"rollback",
		"undo",
		"commit",
		"cleanup",
		"side-effects",
		"error-handling",
		"typescript",
		"typesafe",
		"transaction",
		"compensating-transaction",
		"saga",
		"zero-dependency"
	],
	"main": "./dist/index.cjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.cts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		},
		"./package.json": "./package.json"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsdown",
		"dev": "tsdown --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit",
		"changeset": "changeset",
		"release": "changeset version",
		"release:publish": "changeset publish",
		"prepublishOnly": "pnpm run build",
		"check": "biome check --write",
		"check:ci": "biome ci"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.16",
		"@changesets/cli": "^2.29.0",
		"@types/node": "^25.6.2",
		"lefthook": "^2.1.9",
		"publint": "^0.3.21",
		"tsdown": "^0.22.0",
		"typescript": "^6.0.3",
		"vitest": "^4.1.5"
	},
	"engines": {
		"node": ">=18"
	},
	"packageManager": "pnpm@10.33.4",
	"pnpm": {
		"onlyBuiltDependencies": [
			"lefthook"
		]
	}
}
